# Archivo de ejemplo de configuración de entorno
# Copia este archivo a .env y configura tus valores

# ===================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ===================================
APP_NAME="Artesano Digital"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/artesanoDigital

# ===================================
# CONFIGURACIÓN DE BASE DE DATOS
# ===================================
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=artesano_digital
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# ===================================
# CONFIGURACIÓN DE SESIÓN
# ===================================
SESSION_LIFETIME=120
SESSION_EXPIRE=7200
SESSION_ENCRYPT=false
SESSION_DRIVER=file

# ===================================
# CONFIGURACIÓN DE CORREO ELECTRÓNICO
# ===================================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@artesanodigital.com
MAIL_FROM_NAME="Artesano Digital"

# ===================================
# CONFIGURACIÓN DE UPLOADS
# ===================================
UPLOAD_MAX_SIZE=5242880
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif
UPLOAD_PATH=uploads/
MAX_FILE_SIZE=5242880

# ===================================
# CONFIGURACIÓN DE SEGURIDAD
# ===================================
CSRF_TOKEN_NAME=csrf_token
HASH_ALGORITHM=sha256
ENCRYPTION_KEY=base64:YOUR_32_BYTE_ENCRYPTION_KEY_HERE

# ===================================
# URLs Y RUTAS
# ===================================
BASE_URL=http://localhost/artesanoDigital
ASSETS_URL=http://localhost/artesanoDigital/assets

# ===================================
# CONFIGURACIONES ADICIONALES
# ===================================
# Configurar según el entorno:
# - development: para desarrollo local
# - staging: para pruebas
# - production: para producción

# En producción, asegúrate de:
# - Cambiar APP_DEBUG=false
# - Usar contraseñas seguras para la BD
# - Configurar HTTPS en las URLs
# - Generar clave de encriptación única
